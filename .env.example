# ─────────────────────────────────────────────
# AI Resume Screener — Environment Variables
# Copy this file to .env and fill in the values
# ─────────────────────────────────────────────

# ── External AI APIs ─────────────────────────
GROQ_API_KEY=your_groq_api_key_here
HF_API_TOKEN=your_huggingface_api_token_here

# ── PostgreSQL ────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=resume_screener
POSTGRES_USER=screener
POSTGRES_PASSWORD=changeme

# ── Redis ─────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── MinIO (S3-compatible object storage) ──────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=resumes
MINIO_SECURE=false

# ── Service URLs (used for inter-service calls) ─
UPLOAD_SERVICE_URL=http://upload-service:8001
PARSER_SERVICE_URL=http://parser-service:8002
AI_SCREENER_URL=http://ai-screener-service:8003
